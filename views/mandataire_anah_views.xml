<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_mandataire_anah_list" model="ir.ui.view">
        <field name="name">ibatix.mandataire.anah.list</field>
        <field name="model">ibatix.mandataire.anah</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="email"/>
                <field name="mobile"/>
                <field name="city"/>
                <field name="is_default"/>
            </list>
        </field>
    </record>

    <record id="view_mandataire_anah_form" model="ir.ui.view">
        <field name="name">ibatix.mandataire.anah.form</field>
        <field name="model">ibatix.mandataire.anah</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <h1>
                        <field name="name" placeholder="Nom du mandataire"/>
                    </h1>
                    <group string="Informations du gérant">
                        <group>
                            <field name="titre"/>
                            <field name="prenom"/>
                            <field name="nom_gerant"/>
                            <field name="email"/>
                            <field name="mobile"/>
                            <field name="street" placeholder="Rue..."/>
                            <field name="city" placeholder="Ville"/>
                            <field name="zip" placeholder="Code postal"/>
                        </group>
                    </group>
                    <group string="Propriétés">
                        <group>
                            <field name="representant_administratif"/>
                            <field name="representant_financier"/>
                            <field name="is_default"/>
                        </group>
                        <group>
                            <field name="signature_image" widget="image"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mandataire_anah" model="ir.actions.act_window">
        <field name="name">Mandataires ANAH</field>
        <field name="res_model">ibatix.mandataire.anah</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
