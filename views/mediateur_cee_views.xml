<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_mediateur_cee_list" model="ir.ui.view">
        <field name="name">ibatix.mediateur.cee.list</field>
        <field name="model">ibatix.mediateur.cee</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="city"/>
                <field name="is_default"/>
            </list>
        </field>
    </record>

    <record id="view_mediateur_cee_form" model="ir.ui.view">
        <field name="name">ibatix.mediateur.cee.form</field>
        <field name="model">ibatix.mediateur.cee</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <h1>
                        <field name="name" placeholder="Nom"/>
                    </h1>
                    <group>
                        <group>
                            <field name="street" placeholder="Rue..."/>
                            <field name="city" placeholder="Ville"/>
                            <field name="zip" placeholder="Code postal"/>
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                        <group>
                            <field name="lien_formulaire" placeholder="https://..."/>
                            <field name="website" placeholder="https://..."/>
                            <field name="is_default"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mediateur_cee" model="ir.actions.act_window">
        <field name="name">Médiateurs CEE</field>
        <field name="res_model">ibatix.mediateur.cee</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
