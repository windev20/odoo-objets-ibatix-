<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cofrac_list" model="ir.ui.view">
        <field name="name">ibatix.cofrac.list</field>
        <field name="model">ibatix.cofrac</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="cofrac"/>
                <field name="email"/>
                <field name="date_fin_certificat"/>
                <field name="is_default"/>
            </list>
        </field>
    </record>

    <record id="view_cofrac_form" model="ir.ui.view">
        <field name="name">ibatix.cofrac.form</field>
        <field name="model">ibatix.cofrac</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="logo" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nom"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="street" placeholder="Rue..."/>
                            <field name="city" placeholder="Ville"/>
                            <field name="zip" placeholder="Code postal"/>
                            <field name="email"/>
                            <field name="mobile"/>
                        </group>
                        <group>
                            <field name="siren"/>
                            <field name="cofrac"/>
                            <field name="date_fin_certificat"/>
                            <field name="is_default"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_cofrac" model="ir.actions.act_window">
        <field name="name">Cofrac</field>
        <field name="res_model">ibatix.cofrac</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
