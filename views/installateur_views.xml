<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_installateur_list" model="ir.ui.view">
        <field name="name">ibatix.installateur.list</field>
        <field name="model">ibatix.installateur</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="siren"/>
                <field name="siret"/>
                <field name="is_default"/>
                <field name="is_subcontractor"/>
            </list>
        </field>
    </record>

    <record id="view_installateur_form" model="ir.ui.view">
        <field name="name">ibatix.installateur.form</field>
        <field name="model">ibatix.installateur</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="logo" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nom de la société"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="street" placeholder="Rue..."/>
                            <field name="city" placeholder="Ville"/>
                            <field name="zip" placeholder="Code postal"/>
                            <field name="country_id"/>
                            <field name="phone"/>
                            <field name="mobile"/>
                            <field name="email"/>
                            <field name="website" placeholder="https://..."/>
                        </group>
                        <group>
                            <field name="siren"/>
                            <field name="siret"/>
                            <field name="legal_representative_id"/>
                            <field name="partner_id"/>
                            <field name="company_id"/>
                            <field name="is_default"/>
                            <field name="is_subcontractor"/>
                            <field name="fix_period"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <group>
                        <field name="fix_comment"/>
                    </group>
                    <group>
                        <field name="signature_image" widget="image"/>
                    </group>
                    <notebook>
                        <page string="Assurances" name="assurances">
                            <field name="assurance_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="duration"/>
                                </list>
                            </field>
                        </page>
                        <page string="Qualifications" name="qualifications">
                            <field name="qualification_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="duration"/>
                                    <field name="public_url"/>
                                    <field name="numero_rge"/>
                                    <field name="is_api"/>
                                    <field name="is_downloaded"/>
                                    <field name="qualification_file" widget="binary" filename="qualification_filename"/>
                                    <field name="qualification_filename" invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_installateur" model="ir.actions.act_window">
        <field name="name">Installateurs</field>
        <field name="res_model">ibatix.installateur</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
